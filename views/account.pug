extends base

block content
  main.main
    .user-view
      nav.user-view__menu
        ul.side-nav
          li.side-nav__item.side-nav__item--active
            a(href='#settings') Settings
          li.side-nav__item
            a(href='#bookings') My bookings
          li.side-nav__item
            a(href='#reviews') My reviews
          li.side-nav__item
            a(href='#billing') Billing

      .user-view__content
        .user-settings
          h2.heading-secondary Your account settings

          form.form.form-user-data(action='/api/v1/users/updateMe', method='POST', enctype='multipart/form-data', style='text-align: center;')
            .form__group
              label.form__label(for='name', style='display: block; text-align: left; margin: 0 auto; max-width: 300px;') Name
              input#name.form__input(type='text', value=user.name, name='name', required, style='margin: 0 auto; display: block; max-width: 300px;')

            .form__group
              label.form__label(for='email', style='display: block; text-align: left; margin: 0 auto; max-width: 300px;') Email address
              input#email.form__input(type='email', value=user.email, name='email', required, style='margin: 0 auto; display: block; max-width: 300px;')

            .form__group(style='display: flex; flex-direction: column; align-items: center;')
              label.form__label(for='photo') Photo
              img.form__user-photo(src=`/img/users/${user.photo}`, alt=`Photo of ${user.name}`)
              input#photo.form__upload(type='file', name='photo', accept='image/*')
              label.form__upload-label(for='photo') Choose new photo

            button.btn.btn--small.btn--green(type='submit') Save settings
